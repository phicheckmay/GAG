    if timeSinceLastRound >= ROUND_TIMEOUT and not isRoundActive then
        print("🚨 No round started for " .. math.floor(ROUND_TIMEOUT / 60) .. " minutes! Server hopping...")
        StatusLabel.Text = "⚡ Status: Server hop (no round)..."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 50)
        hopToLowPlayers(true, HOP_SCRAPE_AMOUNT, HOP_MIN_PLAYERS, HOP_MAX_PLAYERS)
    end
end

