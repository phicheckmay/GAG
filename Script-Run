local function canOpenValentineCrate()
    local ProfileData = getProfileData()
    if not ProfileData or not ProfileData.Materials or not ProfileData.Materials.Owned then return false end
    local boxId, currencyKey, required = getValentineBoxIdAndPrice()
    if not boxId or not currencyKey or not required then return false end
    local owned = ProfileData.Materials.Owned[currencyKey]
    owned = (type(owned) == "number" and owned) or tonumber(owned) or 0
    return owned >= required
end

local function openOneValentineCrate()
    local boxId, currencyKey = getValentineBoxIdAndPrice()
    if not boxId or not currencyKey then return nil end
    local success, result = pcall(function()
        return OpenCrateRemote:InvokeServer(boxId, "MysteryBox", currencyKey)
    end)
    if success and result ~= nil and result ~= false then return result end
    return nil
end

local function noMoreDailyQuest()
    local completed, total = getValentineDailyQuestsProgress()
    return total > 0 and completed >= total
end

