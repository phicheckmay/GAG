local function getProfileData()
    local tab = nil
    pcall(function()
        tab = require(game:GetService("ReplicatedStorage"):WaitForChild("Modules"):WaitForChild("ProfileData"))
    end)
    return tab
end

local function getMainEvent()
    local event = nil
    pcall(function()
        local EventInfoService = require(game:GetService("ReplicatedStorage"):WaitForChild("SharedServices"):WaitForChild("EventInfoService"))
        event = EventInfoService:GetMainEvent()
    end)
    return event
end

local function getValentineCurrencyName()
    local event = getMainEvent()
    if not event or not event.EventStartInfo then return nil end
    local info = event.EventStartInfo
    if info.CurrencyName and type(info.CurrencyName) == "string" then return info.CurrencyName end
    if info.KeyName and type(info.KeyName) == "string" then return info.KeyName end
    local shop = info.ShopData
    if shop and type(shop) == "table" then
        for _, item in pairs(shop) do
            if type(item) == "table" and item.Price and type(item.Price) == "table" then
                for key in pairs(item.Price) do
                    if type(key) == "string" and key ~= "Gems" and key ~= "Robux" and key ~= "Coins" then
                        return key
                    end
                end
            end
        end
    end
    return nil
end

local function getValentineCoins()
    local ProfileData = getProfileData()
    if not ProfileData or not ProfileData.Materials or not ProfileData.Materials.Owned then return nil end
    local key = getValentineCurrencyName()
    if not key then return nil end
    local amount = ProfileData.Materials.Owned[key]
    if type(amount) == "number" then return amount end
    local n = tonumber(amount)
    if n ~= nil then return n end
    return 0
end

local function getValentineCratesOpened()
    local ProfileData = getProfileData()
    if not ProfileData then return nil end
    local event = getMainEvent()
    if not event or not event.Title or not event.EventStartInfo or not event.EventStartInfo.Quests then return nil end
    local eventData = ProfileData[event.Title]
    if not eventData or type(eventData) ~= "table" or not eventData.Quests then return nil end
    local profileQuests = eventData.Quests
    for questId, questInfo in pairs(event.EventStartInfo.Quests) do
        if type(questInfo) == "table" and not questInfo.RefreshTime then
            local boxData = profileQuests[questId] or profileQuests[tostring(questId)]
            if boxData and type(boxData) == "table" then
                local n = tonumber(boxData.Progress)
                if n ~= nil then return n end
            end
            return 0
        end
    end
    return nil
end

local function getValentineDailyQuestsProgress()
    local completed, total = 0, 0
    pcall(function()
        local event = getMainEvent()
        if not event or not event.EventStartInfo or not event.EventStartInfo.Quests then return end
        local eventKey = event.Title
        local ProfileData = getProfileData()
        if not ProfileData or not ProfileData[eventKey] or not ProfileData[eventKey].Quests then return end
        local profileQuests = ProfileData[eventKey].Quests
        for questId, questInfo in pairs(event.EventStartInfo.Quests) do
            if type(questInfo) == "table" and questInfo.Quests and #questInfo.Quests > 0 and questInfo.RefreshTime then
                total = #questInfo.Quests
                local progress = profileQuests[questId] and profileQuests[questId].Progress
                if type(progress) ~= "number" then progress = tonumber(progress) end
                if not progress then progress = 0 end
                for i = 1, #questInfo.Quests do
                    local req = questInfo.Quests[i].ChallengeAmount
                    if progress >= req then completed = completed + 1 end
                end
                break
            end
        end
    end)
    return completed, total
end

local function getValentineBoxIdAndPrice()
    local event = getMainEvent()
    if not event or not event.EventStartInfo or not event.EventStartInfo.ShopData then return nil, nil, nil end
    local shop = event.EventStartInfo.ShopData
    for boxId, item in pairs(shop) do
        if type(item) == "table" and item.Type == "MysteryBox" and item.Price and type(item.Price) == "table" then
            local currencyKey = getValentineCurrencyName()
            if currencyKey and item.Price[currencyKey] then
                return boxId, currencyKey, tonumber(item.Price[currencyKey])
            end
        end
    end
    return nil, nil, nil
end

