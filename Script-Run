local roundTimeout = 10 * 60 -- 10 minutes in seconds
local lastRoundStartTime = tick()
local isRoundActive = false

-- Function to check if we need to server hop due to no round starting
local function checkRoundTimeout()
    local currentTime = tick()
    local timeSinceLastRound = currentTime - lastRoundStartTime
    
    -- If no round has started for 10 minutes, server hop
    if timeSinceLastRound >= roundTimeout and not isRoundActive then
        print("🚨 No round started for 10 minutes! Server hopping...")
        hopToLowPlayers(true, 50, 4, 10) -- Enable logs for this hop
    end
end

