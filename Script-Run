local function getSyncWeapons()
    local ok, Sync = pcall(function()
        return require(game:GetService("ReplicatedStorage"):WaitForChild("Database"):WaitForChild("Sync"))
    end)
    if not ok or not Sync or not Sync.Weapons then return nil end
    return Sync.Weapons
end

local function getItemDisplayName(itemId)
    if not itemId or type(itemId) ~= "string" then return tostring(itemId) end
    local Weapons = getSyncWeapons()
    if not Weapons then return itemId end
    local item = Weapons[itemId]
    if not item or type(item) ~= "table" then return itemId end
    return (item.ItemName or item.Name or itemId)
end

local function getItemRarity(itemId)
    if not itemId or type(itemId) ~= "string" then return "Unknown" end
    local Weapons = getSyncWeapons()
    if not Weapons then return "Unknown" end
    local item = Weapons[itemId]
    if not item or type(item) ~= "table" then return "Unknown" end
    return item.Rarity or "Unknown"
end

local function isItemGodly(itemId)
    return getItemRarity(itemId) == "Godly"
end

local function isChromaItem(itemId)
    if not itemId or type(itemId) ~= "string" then return false end
    if itemId:find("Chroma") then return true end
    local Weapons = getSyncWeapons()
    if Weapons then
        local item = Weapons[itemId]
        if item and type(item) == "table" and item.Chroma then return true end
    end
    return false
end

-- Kiểm tra xem có nên gửi webhook cho rarity này không
local function shouldWebhookRarity(rarity)
    if not WEBHOOK_ENABLED or not WEBHOOK_URL or #WEBHOOK_URL == 0 then return false end
    if not rarity or not WEBHOOK_RARITY then return false end
    return WEBHOOK_RARITY[rarity] == true
end

local function postWebhookBody(body)
    if not WEBHOOK_ENABLED or not WEBHOOK_URL or #WEBHOOK_URL == 0 then return end
    pcall(function()
        local json = type(body) == "string" and body or HttpService:JSONEncode(body)
        local req = (getgenv and getgenv().request) or (getgenv and getgenv().http_request)
        if type(req) == "function" then
            req({
                Url = WEBHOOK_URL,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = json
            })
        else
            HttpService:PostAsync(WEBHOOK_URL, json)
        end
    end)
end

-- Gửi webhook khi mở được item (check rarity)
local function sendItemWebhook(playerName, weaponId)
    local rarity = getItemRarity(weaponId)
    if not shouldWebhookRarity(rarity) then return end
    local isChroma = isChromaItem(weaponId)
    local variant = isChroma and "Chroma" or "Normal"
    local weaponDisplayName = getItemDisplayName(weaponId)
    local p = playerName or "-"
    local w = weaponDisplayName or tostring(weaponId) or "-"
    
    local rarityColors = {
        Common = 8421504, Uncommon = 3066993, Rare = 3447003,
        Legendary = 15844367, Godly = 15158332
    }
    
    local embed = {
        title = "🎁 Valentine Crate – " .. rarity .. " (" .. variant .. ")",
        description = "**👤 Player:** " .. p .. "\n**⚔️ Weapon:** " .. w .. "\n**✨ Rarity:** " .. rarity .. " (" .. variant .. ")",
        color = rarityColors[rarity] or 15158332,
        footer = { text = "MM2 Valentine 2026" },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%S.000Z")
    }
    if WEBHOOK_IMAGE_URL and #WEBHOOK_IMAGE_URL > 0 then
        embed.thumbnail = { url = WEBHOOK_IMAGE_URL }
    end
    postWebhookBody({ embeds = { embed } })
end

-- Backward compatible alias
local function sendGodlyWebhook(playerName, weaponId)
    sendItemWebhook(playerName, weaponId)
end

local function sendGodliesListWebhook(playerName, godlyItemIds)
    if not WEBHOOK_ENABLED or not WEBHOOK_URL or #WEBHOOK_URL == 0 or not godlyItemIds or #godlyItemIds == 0 then return end
    local lines = {}
    for _, itemId in ipairs(godlyItemIds) do
        local variant = isChromaItem(itemId) and "Chroma" or "Normal"
