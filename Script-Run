            local mins = math.floor((elapsed % 3600) / 60)
            local secs = elapsed % 60
            
            if days > 0 then
                OnlineLabel.Text = string.format("🕐 Online: %d ngày %02d:%02d:%02d", days, hours, mins, secs)
            else
                OnlineLabel.Text = string.format("🕐 Online: %02d:%02d:%02d", hours, mins, secs)
            end
            
            -- Update target progress
            if type(coins) == "number" then
                local pct = math.floor(coins / VALENTINE_TARGET * 100)
                TargetLabel.Text = "🎯 Target: " .. displayNum(coins) .. " / " .. formatNumber(VALENTINE_TARGET) .. " (" .. pct .. "%)"
                if coins >= VALENTINE_TARGET then
                    TargetLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
                end
            end
        end)
    end
end)

