local function getInventory()
    local replica = PlayerStateClient:GetLocalReplica()
    if not replica or not replica.Data or not replica.Data.Inventory then return {} end
    return replica.Data.Inventory
end

local function entryDisplayName(entry)
    if type(entry) ~= "table" then return nil end
    return entry.Name or entry.Type or entry.ItemType or nil
end

local function buildItemList()
    local inv    = getInventory()
    local result = {}
    for category, data in pairs(inv) do
        if type(data) ~= "table" then continue end
        if listCategories[category] then
            local counts, sendable = {}, {}
            for _, entry in pairs(data) do
                local name = entryDisplayName(entry)
                if not name then continue end
                counts[name] = (counts[name] or 0) + 1
                if not entry.Equipped then
                    sendable[name] = (sendable[name] or 0) + 1
                end
            end
            for name, total in pairs(counts) do
                result[#result+1] = {
                    Category = category, Key = name,
                    Count = total, Sendable = sendable[name] or 0, IsList = true,
                }
            end
        else
            for key, c in pairs(data) do
                local n = tonumber(c)
                if n and n > 0 then
                    result[#result+1] = {
                        Category = category, Key = key,
                        Count = n, Sendable = n, IsList = false,
                    }
                end
            end
        end
    end
    return result
end

local function getIdsByName(category, name, limit)
    local inv  = getInventory()
    local data = inv[category]
    local ids  = {}
    if type(data) ~= "table" then return ids end
    for id, entry in pairs(data) do
        local ename = entryDisplayName(entry)
        if ename == name and not entry.Equipped then
            ids[#ids+1] = id
            if #ids >= limit then break end
        end
    end
    return ids
end

----------------------------------------------------------------
-- CLAIM MAIL (cho COLLECT_MAIL)
----------------------------------------------------------------
local function claimAllMail()
    local ok, inbox = pcall(function()
        return Networking.Mailbox.OpenInbox:Fire()
    end)
    if not ok or type(inbox) ~= "table" then return 0, "Khong mo duoc inbox" end

    local claimable = {}
    for giftId, payload in pairs(inbox) do
        if type(payload) == "table" then
            local kind = payload.Kind or payload.Type or ""
            if kind ~= "GuildInvite" then
                claimable[#claimable+1] = giftId
            end
        end
    end
    if #claimable == 0 then return 0, "Inbox trong" end

    local claimed, failed = 0, 0
    local RETRY_WAIT  = 1.5
    local MAX_RETRIES = 3
    for _, giftId in ipairs(claimable) do
        local ok_final = false
        for attempt = 1, MAX_RETRIES do
            local pok, result = pcall(function()
                return Networking.Mailbox.Claim:Fire(giftId)
            end)
            if pok and result == true then ok_final = true ; break end
            if attempt < MAX_RETRIES then task.wait(RETRY_WAIT) end
        end
        if ok_final then claimed += 1 else failed += 1 end
        task.wait(CLAIM_DELAY)
    end

    if failed == 0 then
        return claimed, "Da nhan "..claimed.."/"..#claimable.." mail"
    else
        return claimed, "Nhan "..claimed.."/"..#claimable.." ("..failed.." that bai)"
    end
end

