-- ANTI-AFK
----------------------------------------------------------------
local function setupAntiAfk() pcall(function()
    local VU = game:GetService("VirtualInputManager")
    local RS = ReplicatedStorage

    local function killHop()
        local ok, Net = pcall(require, RS.SharedModules.Networking)
        if not ok or type(Net) ~= "table" then return end
        local rh = Net.AntiAfk and Net.AntiAfk.RequestHop
        if type(rh) ~= "table" then return end
        if not rh.__hopKilled then
            rh.Fire = function() end
            rh.__hopKilled = true
        end
    end
    local function killFlag()
        local ok, flags = pcall(require, RS.SharedModules.Flags.AntiAfkFlags)
        if not ok or type(flags) ~= "table" or type(flags.Enabled) ~= "table" then return end
        pcall(function() flags.Enabled.Get    = function() return false    end end)
        pcall(function() flags.IdleSeconds.Get = function() return math.huge end end)
    end
    local function fakeInput()
        pcall(function()
            VU:SendKeyEvent(true,  Enum.KeyCode.RightControl, false, game)
            task.wait(0.05)
            VU:SendKeyEvent(false, Enum.KeyCode.RightControl, false, game)
        end)
    end
    local function clearSignal(signal)
        local node = signal.Next
        while node and node ~= signal do node.Function = nil ; node = node.Next end
        signal.Next = signal ; signal.Previous = signal
    end
    pcall(function() clearSignal(Networking.AntiAfk.RequestHop.OnClientEvent) end)
    pcall(function()
        if type(getconnections) == "function" then
            for _, conn in pairs(getconnections(LocalPlayer.Idled)) do conn:Disable() end
        end
    end)
    pcall(function()
        local VU2 = game:GetService("VirtualUser")
        LocalPlayer.Idled:Connect(function()
            VU2:ClickButton2(Vector2.new(math.random(0,1000), math.random(0,1000)))
        end)
    end)
    pcall(function()
        if type(hookmetamethod) ~= "function" or type(newcclosure) ~= "function" then return end
        local blocked = {
            ["Server Closing"]=true, ["Idle Tracking: Update Timer"]=true, ["Move Server"]=true,
        }
        local old ; old = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            if not checkcaller() and blocked[tostring(self)] then return nil end
            return old(self, ...)
        end))
    end)
    killFlag()
    task.spawn(function() while true do pcall(killHop) pcall(killFlag) task.wait(AFKKILLLOOP) end end)
    task.spawn(function() while true do fakeInput() task.wait(AFKINTERVAL) end end)
end) end

