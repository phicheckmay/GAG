-- ========================================================================
-- AUTO SELECT TABLET - MM2 (Standalone, không dùng firesignal)
-- ========================================================================

local function clickButton(btn)
    pcall(function() btn.MouseButton1Click:Fire() end)
    pcall(function() btn.Activated:Fire() end)
end

task.spawn(function()
    task.wait(1)
    local maxWaitTime = 60
    local startTime = tick()
    local clicked = false

    print("[TabletSelect] Đang tìm màn hình chọn device...")

    while tick() - startTime < maxWaitTime and not clicked do
        pcall(function()
            local playerGui = game.Players.LocalPlayer:FindFirstChild("PlayerGui")
            if not playerGui then return end

            -- Scan toàn bộ PlayerGui tìm button Tablet
            for _, obj in pairs(playerGui:GetDescendants()) do
                if obj:IsA("TextButton") or obj:IsA("ImageButton") then
                    local name = obj.Name:lower()
                    local text = (obj:IsA("TextButton") and obj.Text or ""):lower()
                    if name:find("tablet") or text:find("tablet") then
                        print("[TabletSelect] Found: " .. obj:GetFullName())
                        clickButton(obj)
                        task.wait(0.1)
                        clickButton(obj)
                        clicked = true
                        return
                    end
                end
            end
        end)

        if not clicked then task.wait(0.3) end
    end

    if clicked then
        warn("[TabletSelect] Done!")
    else
        warn("[TabletSelect] Không tìm thấy sau " .. maxWaitTime .. "s, in toàn bộ buttons:")
        pcall(function()
            local playerGui = game.Players.LocalPlayer:FindFirstChild("PlayerGui")
            for _, gui in pairs(playerGui:GetChildren()) do
                print("GUI: " .. gui.Name)
                for _, v in pairs(gui:GetDescendants()) do
                    if v:IsA("TextButton") or v:IsA("ImageButton") then
                        print("  Button: " .. v.Name .. " | Text: " .. tostring(v:IsA("TextButton") and v.Text or "-"))
                    end
                end
            end
        end)
    end
end)
