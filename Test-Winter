-- ========================================================================
-- AUTO SELECT TABLET - MM2 (Standalone)
-- ========================================================================

local function clickButton(btn)
    -- Thử nhiều cách click khác nhau
    pcall(function() firesignal(btn.MouseButton1Click) end)
    pcall(function() btn.MouseButton1Click:Fire() end)
    pcall(function()
        local pos = btn.AbsolutePosition + btn.AbsoluteSize / 2
        local inputObj = Instance.new("InputObject")
        inputObj.UserInputType = Enum.UserInputType.Touch
        inputObj.Position = Vector3.new(pos.X, pos.Y, 0)
        btn:SimulateMouseMovement(pos.X, pos.Y)
    end)
end
    local startTime = tick()
    local clicked = false

    print("[TabletSelect] Đang tìm màn hình chọn device...")

    while tick() - startTime < maxWaitTime and not clicked do
        pcall(function()
            local playerGui = game.Players.LocalPlayer:FindFirstChild("PlayerGui")
            if not playerGui then return end

            -- Cách 1: path cũ
            local deviceSelect = playerGui:FindFirstChild("DeviceSelect")
            if deviceSelect then
                print("[TabletSelect] Tìm thấy DeviceSelect, children:")
                for _, v in pairs(deviceSelect:GetDescendants()) do
                    if v:IsA("TextButton") or v:IsA("ImageButton") then
                        print("  Button: " .. v:GetFullName() .. " | Text: " .. tostring(v:IsA("TextButton") and v.Text or "-"))
                    end
                end

                local container = deviceSelect:FindFirstChild("Container")
                if container then
                    local tablet = container:FindFirstChild("Tablet")
                    if tablet then
                        local button = tablet:FindFirstChild("Button")
                        if button then
                            clickButton(button)
                            clicked = true
                            print("[TabletSelect] ✅ Clicked via path cũ")
                            return
                        end
                    end
                end
            end

            -- Cách 2: scan toàn bộ PlayerGui
            for _, obj in pairs(playerGui:GetDescendants()) do
                if obj:IsA("TextButton") or obj:IsA("ImageButton") then
                    local name = obj.Name:lower()
                    local text = (obj:IsA("TextButton") and obj.Text or ""):lower()
                    if name:find("tablet") or text:find("tablet") then
                        print("[TabletSelect] ✅ Found: " .. obj:GetFullName() .. " | Text: " .. text)
                        clickButton(obj)
                        clicked = true
                        return
                    end
                end
            end
        end)

        if not clicked then task.wait(0.5) end
    end

    if clicked then
        warn("[TabletSelect] ✅ Tablet đã được chọn!")
    else
        warn("[TabletSelect] ❌ Không tìm thấy Tablet button sau " .. maxWaitTime .. "s")
        -- In toàn bộ GUI để debug
        pcall(function()
            local playerGui = game.Players.LocalPlayer:FindFirstChild("PlayerGui")
            if playerGui then
                print("[TabletSelect] Toàn bộ ScreenGui trong PlayerGui:")
                for _, gui in pairs(playerGui:GetChildren()) do
                    print("  " .. gui.Name .. " (" .. gui.ClassName .. ")")
                end
            end
        end)
    end
end)
