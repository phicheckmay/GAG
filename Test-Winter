-- AUTO SELECT TABLET - Ronix (dùng simulateclick)

task.wait(2)

local playerGui = game.Players.LocalPlayer.PlayerGui
local found = false

for i = 1, 120 do
    for _, obj in pairs(playerGui:GetDescendants()) do
        local name = obj.Name:lower()
        if (obj:IsA("TextButton") or obj:IsA("ImageButton")) and (name:find("tablet") or name:find("tabletperk")) then
            warn("Found: " .. obj:GetFullName())
            -- Ronix dùng simulateclick
            local ok, err = pcall(function()
                simulateclick(obj)
            end)
            if ok then
                warn("simulateclick OK")
                found = true
                break
            else
                warn("simulateclick fail: " .. tostring(err))
            end

            -- Thử firebutton
            local ok2, err2 = pcall(function()
                firebutton(obj)
            end)
            if ok2 then
                warn("firebutton OK")
                found = true
                break
            else
                warn("firebutton fail: " .. tostring(err2))
            end

            -- Thử click2d
            local ok3, err3 = pcall(function()
                local pos = obj.AbsolutePosition + obj.AbsoluteSize / 2
                click2d(pos.X, pos.Y)
            end)
            if ok3 then
                warn("click2d OK")
                found = true
                break
            else
                warn("click2d fail: " .. tostring(err3))
            end

            found = true -- dù sao cũng break để xem log
            break
        end
    end
    if found then break end
    task.wait(0.5)
end

if not found then
    warn("Không tìm thấy button!")
end
