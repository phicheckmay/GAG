local function bxor(a,b)
    if bit32 and bit32.bxor then return bit32.bxor(a,b) end
    local res, bit = 0, 1
    while a > 0 or b > 0 do
        local aa, bb = a % 2, b % 2
        if aa ~= bb then res = res + bit end
        a = math.floor(a / 2)
        b = math.floor(b / 2)
        bit = bit * 2
    end
    return res
end

local function hexToBytes(hex)
    local out = {}
    for i = 1, #hex, 2 do
        out[#out + 1] = tonumber(hex:sub(i, i + 1), 16)
    end
    return out
end

